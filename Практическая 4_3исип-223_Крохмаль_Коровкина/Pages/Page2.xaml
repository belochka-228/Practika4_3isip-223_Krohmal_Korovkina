<Page x:Class="Практическая_4_3исип_223_Крохмаль_Коровкина.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Практическая_4_3исип_223_Крохмаль_Коровкина.Pages"
      mc:Ignorable="d" 
      Title="Page2">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Row="0" Grid.ColumnSpan="2" Source="/Images/2 формула.png" 
               MaxHeight="100" Margin="5" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Выберите: " VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <RadioButton x:Name="rbSh" Content="sh(x)" GroupName="func" IsChecked="True" Margin="5" 
                         ToolTip="Гиперболический синус"/>
            <RadioButton x:Name="rbSquare" Content="x²" GroupName="func" Margin="5" 
                         ToolTip="Квадрат x"/>
            <RadioButton x:Name="rbExp" Content="eˣ" GroupName="func" Margin="5" 
                         ToolTip="Экспонента"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="x:" VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="txtX" Grid.Row="2" Grid.Column="1" Margin="5" Padding="3" 
                 ToolTip="Введите x"/>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="q:" VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="txtQ" Grid.Row="3" Grid.Column="1" Margin="5" Padding="3" 
                 ToolTip="Введите q"/>
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Результат:" VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="txtResult" Grid.Row="4" Grid.Column="1" Margin="5" Padding="3" 
                 IsReadOnly="True" ToolTip="Результат вычисления"/>


        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Вычислить" Click="btnCalc_Click" Margin="10" Padding="15,5" 
                    ToolTip="Рассчитать k по условию"/>
            <Button Content="Очистить" Click="btnClear_Click" Margin="10" Padding="15,5" 
                    ToolTip="Очистить поля"/>
        </StackPanel>
    </Grid>
</Page>
